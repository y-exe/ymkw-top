---
import Layout from "../layouts/Layout.astro";
import { RiBarChartBoxFill, RiCalendarScheduleFill } from "react-icons/ri";
import { InteractiveHoverButton } from "../components/ui/InteractiveHoverButton";

export const prerender = false;

const date = new Date();
date.setDate(0);
const prevMonthYear = date.getFullYear();
const prevMonth = date.getMonth() + 1;

const title = "やまかわてるき";
const description =
  "やまかわてるき鯖の統計データを可視化する公認WEBダッシュボードです。Discordのランキング、活動量、月間レポートを確認できます。";
---

<Layout title={title} description={description} hideNavigation={true}>
  <style>
    @font-face {
      font-family: "ZakkuriGothic";
      src: url("/fonts/ZakkuriGothicFree-Black.otf") format("opentype");
      font-display: swap;
    }
    :root {
      --box-size: 14rem;
    }
    @media (min-width: 640px) {
      :root {
        --box-size: 18rem;
      }
    }
    @media (min-width: 1024px) {
      :root {
        --box-size: 22rem;
      }
    }
    .wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: space-between;
      min-height: 100vh;
      width: 100%;
      position: relative;
      overflow: hidden;
      background-color: hsl(var(--background));
      padding: 2rem 1.5rem;
      font-family: "Outfit", sans-serif;
    }
    .bg-text-container {
      position: absolute;
      inset: 0;
      z-index: 0;
      opacity: 0.04;
      pointer-events: none;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .bg-text-content {
      font-family: "Dela Gothic One", cursive;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-size: 52vw;
      line-height: 0.86;
      text-align: center;
      transform: scale(1.08, 2.9);
      user-select: none;
      color: hsl(var(--foreground));
      white-space: normal;
    }
    .bg-text-content span {
      display: block;
      white-space: nowrap;
    }
    .header-logo {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 10;
      margin-bottom: 2rem;
    }
    .header-sub {
      font-weight: 700;
      font-size: 0.75rem;
      letter-spacing: 0.3em;
      color: hsl(var(--muted-foreground));
      text-transform: uppercase;
    }
    .header-main {
      font-weight: 800;
      font-size: 1.5rem;
      letter-spacing: -0.05em;
      color: hsl(var(--foreground));
      margin-top: 0.25rem;
    }
    .footer {
      z-index: 10;
      text-align: center;
      font-size: 0.5rem;
      color: hsl(var(--muted-foreground));
      font-family: monospace;
      margin-top: 2rem;
      transform: translateY(1.25rem);
    }
    .main-grid {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      width: 100%;
      max-width: 80rem;
      z-index: 10;
    }
    @media (min-width: 1024px) {
      .bg-text-content {
        flex-direction: row;
        font-size: 25vw;
        line-height: 1;
        transform: scale(1, 3.5);
        white-space: nowrap;
      }
      .header-logo {
        margin-bottom: 0;
      }
      .footer {
        font-size: 0.625rem;
        margin-top: 0;
        transform: none;
      }
      .main-grid {
        flex-direction: row;
        gap: 4rem;
      }
    }
    .nav-card {
      position: relative;
      width: 100%;
      overflow: hidden;
      background: #050505;
      border: 1px solid #1a1a1a;
      color: #f5f7fb;
      padding: 2rem;
      border-radius: 2rem;
      box-shadow: 0 18px 42px -24px rgba(0, 0, 0, 0.9);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    @media (min-width: 1024px) {
      .nav-card {
        width: 18rem;
      }
    }
    .card-bg-icon {
      position: absolute;
      right: -3.25rem;
      bottom: -3.75rem;
      z-index: 0;
      width: 14.5rem;
      height: 14.5rem;
      color: #353535;
      opacity: 0.9;
      pointer-events: none;
      transform: rotate(-8deg);
    }
    .card-bg-icon-rank {
      right: -3rem;
      bottom: -3.85rem;
      transform: rotate(7deg);
    }
    .card-title {
      position: relative;
      z-index: 1;
      font-weight: 700;
      font-size: 1.125rem;
      color: #f7f8fc;
      margin-bottom: 0.25rem;
    }
    .card-sub {
      position: relative;
      z-index: 1;
      font-size: 0.75rem;
      color: #9b9b9b;
      font-family: monospace;
      margin-bottom: 1rem;
    }
    .card-action {
      position: relative;
      z-index: 1;
      margin: 0;
    }
    .red-box {
      position: relative;
      background-color: #ff0000;
      border-radius: 3rem;
      width: var(--box-size);
      height: var(--box-size);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 25px 50px -12px rgba(239, 68, 68, 0.4);
    }
    .char-container {
      width: 82%;
      height: 82%;
      position: relative;
    }
    .char {
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 50%;
      height: 50%;
      color: white;
      font-family: "ZakkuriGothic", sans-serif;
      font-size: calc(var(--box-size) * 0.82 * 0.52);
      line-height: 0.65;
      animation-duration: 4s;
      animation-iteration-count: infinite;
      animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    }
    .char-1 {
      animation-name: move-ya;
    }
    .char-2 {
      animation-name: move-ma;
    }
    .char-3 {
      animation-name: move-ka;
    }
    .char-4 {
      animation-name: move-wa;
    }
    @keyframes move-ya {
      0%,
      100% {
        top: 0;
        left: 0;
      }
      15%,
      25% {
        top: 50%;
        left: 0;
      }
      40%,
      50% {
        top: 50%;
        left: 50%;
      }
      65%,
      75% {
        top: 0;
        left: 50%;
      }
    }
    @keyframes move-ma {
      0%,
      100% {
        top: 0;
        left: 50%;
      }
      15%,
      25% {
        top: 0;
        left: 0;
      }
      40%,
      50% {
        top: 50%;
        left: 0;
      }
      65%,
      75% {
        top: 50%;
        left: 50%;
      }
    }
    @keyframes move-ka {
      0%,
      100% {
        top: 50%;
        left: 0;
      }
      15%,
      25% {
        top: 50%;
        left: 50%;
      }
      40%,
      50% {
        top: 0;
        left: 50%;
      }
      65%,
      75% {
        top: 0;
        left: 0;
      }
    }
    @keyframes move-wa {
      0%,
      100% {
        top: 50%;
        left: 50%;
      }
      15%,
      25% {
        top: 0;
        left: 50%;
      }
      40%,
      50% {
        top: 0;
        left: 0;
      }
      65%,
      75% {
        top: 50%;
        left: 0;
      }
    }
  </style>

  <div
    class="wrapper animate-in fade-in slide-in-from-bottom-4 duration-1000 ease-out"
  >
    <div class="bg-text-container">
      <span class="bg-text-content">
        <span>杉山</span>
        <span>啓太</span>
      </span>
    </div>
    <div class="header-logo">
      <span class="header-sub">サーバー分析</span>
      <h1 class="header-main">ymkw.top</h1>
    </div>
    <div class="main-grid">
      <div class="nav-card order-2 lg:order-1">
        <RiCalendarScheduleFill className="card-bg-icon" />
        <h2 class="card-title">月間レポート</h2>
        <p class="card-sub">{prevMonthYear}.{prevMonth} レポート</p>
        <form class="card-action" action={`/month/${prevMonthYear}/${prevMonth}`} method="get">
          <InteractiveHoverButton text="Open" type="submit" />
        </form>
      </div>
      <div class="order-1 lg:order-2">
        <div class="red-box">
          <div class="char-container">
            <span class="char char-1">や</span>
            <span class="char char-2">ま</span>
            <span class="char char-3">か</span>
            <span class="char char-4">わ</span>
          </div>
        </div>
      </div>
      <div class="nav-card order-3">
        <RiBarChartBoxFill className="card-bg-icon card-bg-icon-rank" />
        <h2 class="card-title">累計ランキング</h2>
        <p class="card-sub">All Time</p>
        <form class="card-action" action="/all" method="get">
          <InteractiveHoverButton text="Open" type="submit" />
        </form>
      </div>
    </div>
    <div class="footer"><p>© 2026 ymkw.top</p></div>
  </div>
</Layout>
