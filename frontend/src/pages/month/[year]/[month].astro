---
import Layout from '../../../layouts/Layout.astro';
import Dashboard from '../../../components/Dashboard.jsx';
import { fetchAPI } from "@/lib/api";
import { formatNumber } from "@/lib/seo";

const { year, month } = Astro.params;
const url = Astro.url;

const nowUTC = new Date();
const jstDate = new Date(nowUTC.getTime() + (9 * 60 * 60 * 1000));
const currentYear = jstDate.getUTCFullYear();
const currentMonth = jstDate.getUTCMonth() + 1;
const targetYear = parseInt(year || "0");
const targetMonth = parseInt(month || "0");
const isValidMonth = Number.isInteger(targetYear) && Number.isInteger(targetMonth) && targetYear >= 2020 && targetMonth >= 1 && targetMonth <= 12;
const isRestricted = (targetYear > currentYear) || (targetYear === currentYear && targetMonth >= currentMonth);

const ADMIN_PASSWORD_HASH = "2f11bf70add2518a3c218295612a992132459445ffd2e375db85402341b3d5f3";
const isAuthorized = Astro.cookies.get('admin_auth')?.value === 'true';

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const inputPassword = formData.get("password")?.toString() || "";
        const msgBuffer = new TextEncoder().encode(inputPassword);
        const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
        const hashArray = Array.from(new Uint8Array(hashBuffer));
        const inputHash = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');

        if (inputHash === ADMIN_PASSWORD_HASH) {
            Astro.cookies.set('admin_auth', 'true', { path: '/', maxAge: 86400, httpOnly: true, secure: true, sameSite: 'lax' });
            return Astro.redirect(url.pathname + url.search);
        }
    } catch (e) {
        console.error("Auth Error:", e);
    }
}

const channelId = url.searchParams.get('channel');
let userId = Astro.cookies.get('user_id')?.value;
if (userId === 'guest') userId = null;

if (!isValidMonth) {
    Astro.response.status = 404;
}

Astro.response.headers.set('Cache-Control', isRestricted || !isValidMonth ? 'no-store' : 'public, s-maxage=600');

const pageTitle = `${year}年${month}月 月間レポート`;
const pageDescription = `${year}年${month}月のやまかわてるき鯖の統計情報。メッセージ数ランキング、アクティビティヒートマップ、チャットの盛り上がりを分析したレポート。`;

let seoRanking: any[] = [];
let seoOverall: any = null;
if (isValidMonth && !isRestricted) {
    try {
        const [rankingRes, analysisRes] = await Promise.all([
            fetchAPI(`/ranking/monthly/${targetYear}/${targetMonth}`, { retries: 1 }),
            fetchAPI(`/stats/analysis/${targetYear}/${targetMonth}`, { retries: 1 }),
        ]);
        if (rankingRes.ok) {
            const ranking = await rankingRes.json();
            if (Array.isArray(ranking)) seoRanking = ranking.slice(0, 10);
        }
        if (analysisRes.ok) {
            seoOverall = await analysisRes.json();
        }
    } catch (e) {
        console.error("Monthly SEO Fetch Error:", e);
    }
}

const breadcrumbs = [
    { name: "トップ", item: "https://www.ymkw.top/" },
    { name: "月間レポート", item: "https://www.ymkw.top/" },
    { name: `${year}年${month}月`, item: `https://www.ymkw.top/month/${year}/${month}` }
];
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs} noindex={isRestricted || !isValidMonth}>
    {!isRestricted && isValidMonth && (
        <section class="mb-8 rounded-lg border border-gray-200 bg-white p-5 text-gray-900 shadow-sm">
            <h1 class="text-2xl font-black">{pageTitle}</h1>
            <p class="mt-3 max-w-3xl text-sm leading-7 text-gray-600">
                {pageDescription}
                {seoOverall?.total ? ` この月の集計対象メッセージは${formatNumber(seoOverall.total)}件です。` : ""}
                {seoOverall?.unique_users ? ` 参加ユーザー数は${formatNumber(seoOverall.unique_users)}人です。` : ""}
            </p>
            {seoRanking.length > 0 && (
                <div class="mt-5">
                    <h2 class="text-sm font-bold text-gray-700">月間ランキング上位</h2>
                    <ol class="mt-3 grid gap-2 sm:grid-cols-2 lg:grid-cols-5">
                        {seoRanking.slice(0, 5).map((item, index) => (
                            <li class="rounded-md bg-gray-50 px-3 py-2 text-sm">
                                <span class="font-bold">{index + 1}位</span>
                                <span class="ml-2">{item.display_name || item.username}</span>
                                <span class="ml-1 text-gray-500">{formatNumber(item.count)}回</span>
                            </li>
                        ))}
                    </ol>
                </div>
            )}
        </section>
    )}
    {isRestricted && !isAuthorized ? (
        <>
            <div class="h-[60vh] flex flex-col items-center justify-center animate-fade-in p-4">
                <div class="bg-white p-10 rounded-[2.5rem] border border-gray-200 shadow-2xl max-w-sm w-full text-center relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-2 bg-blue-600"></div>
                    <h2 class="text-2xl font-black text-gray-900 mb-2 font-outfit">未公開エリア</h2>
                    <p class="text-sm text-gray-500 mb-8 leading-relaxed">{year}年{month}月のレポートは未公開です。パスワードを入力してください。</p>
                    
                    <form method="POST" class="space-y-4" data-astro-reload>
                        <input type="password" name="password" placeholder="パスワード" class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl text-center font-bold outline-none focus:border-blue-500 transition-all" required />
                        <button type="submit" class="w-full py-4 bg-gray-900 text-white font-bold rounded-2xl hover:bg-black transition-all">解除</button>
                    </form>
                    
                    <button onclick="history.back()" class="mt-8 text-xs font-bold text-gray-400 hover:text-gray-900 flex items-center justify-center gap-2 mx-auto">前のページに戻る</button>
                </div>
            </div>
            <script is:inline>
                (function(){
                    const screen = document.getElementById('loading-screen');
                    if(screen) {
                        screen.style.opacity = '0';
                        screen.style.pointerEvents = 'none';
                        setTimeout(() => screen.style.display = 'none', 500);
                    }
                })();
            </script>
        </>
    ) : (
        <Dashboard client:load year={year} month={month} channelId={channelId} userId={userId} />
    )}
</Layout>
