---
import Layout from "../layouts/Layout.astro";
import { History, ArrowLeft } from "lucide-react";
---

<Layout title="No Data Yet" noindex={true}>
  <div class="min-h-[70vh] flex flex-col items-center justify-center animate-fade-in p-6">
    <div class="bg-[#f8f8f8] p-10 rounded-2xl max-w-md w-full text-center">
      <div class="w-16 h-16 bg-white text-[#111F35] rounded-2xl flex items-center justify-center mx-auto mb-6">
        <History className="w-10 h-10" />
      </div>

      <p class="text-xs font-black text-gray-400 uppercase tracking-[0.24em] mb-2">
        Oops!!
      </p>
      <h1 class="text-2xl font-black text-gray-900 mb-4 font-outfit">
        Not Yet Generated
      </h1>
      <p class="text-sm text-gray-500 mb-8 leading-relaxed">
        全期間の集計データは<br />
        まだ作成されていません。
        <span class="text-xs font-bold text-gray-400 mt-3 block leading-relaxed">
          管理者が Discord で /open コマンドを実行すると<br />
          ここに表示されます。
        </span>
      </p>

      <button
        onclick="history.back()"
        class="w-full py-4 bg-gray-900 text-white font-bold rounded-2xl hover:bg-black transition-all active:scale-[0.98] flex items-center justify-center gap-2"
      >
        <ArrowLeft className="w-4 h-4" />
        戻る
      </button>
    </div>
  </div>
</Layout>
