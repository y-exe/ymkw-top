---
import {
  Breadcrumb,
  BreadcrumbList,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbSeparator,
  BreadcrumbPage,
} from "./ui/breadcrumb.tsx";
import { Home } from "lucide-react";
import { LogoutButton, LoginButton } from "./AuthButtons.jsx";
import { ToggleTheme } from "./ToggleTheme.jsx";
import { fetchAPI } from "@/lib/api";

const { url } = Astro;
const channelId = url.searchParams.get("channel");

let channelName = "All Channels";
if (channelId) {
  try {
    const res = await fetchAPI("/api/channels");
    if (res.ok) {
      const channels: any[] = await res.json();
      const found = channels.find(
        (c: any) => String(c.id) === String(channelId),
      );
      if (found) channelName = found.name;
    }
  } catch (e) {}
}

const userId = Astro.cookies.get("user_id")?.value;
const userNameRaw = Astro.cookies.get("user_name")?.value;
const userName = userNameRaw ? decodeURIComponent(userNameRaw) : null;
const userAvatar = Astro.cookies.get("user_avatar")?.value;

const parts = url.pathname.split("/").filter(Boolean);
const mode = parts[0] === "open" ? "Overview" : "Monthly";
const year = parts[1];
const month = parts[2];
---

<header
  class="h-16 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60 border-b border-border hidden md:flex items-center justify-between px-8 sticky top-0 z-40"
>
  <!-- 左側のナビゲーション -->
  <Breadcrumb>
    <BreadcrumbList>
      <BreadcrumbItem>
        <BreadcrumbLink href="/" className="flex items-center gap-1.5"
          ><Home className="w-4 h-4" />Home</BreadcrumbLink
        >
      </BreadcrumbItem>
      <BreadcrumbSeparator />
      <BreadcrumbItem>
        <BreadcrumbLink href="#">{mode}</BreadcrumbLink>
      </BreadcrumbItem>
      {year && !url.pathname.includes("/open/") && <BreadcrumbSeparator />}
      {
        year && !url.pathname.includes("/open/") && (
          <BreadcrumbItem>
            <BreadcrumbPage>
              {year}年{month ? ` ${month}月` : ""}
            </BreadcrumbPage>
          </BreadcrumbItem>
        )
      }
      <BreadcrumbSeparator />
      <BreadcrumbItem>
        <BreadcrumbPage
          class={channelId
            ? "text-primary bg-primary/10 px-2 py-0.5 rounded font-bold flex items-center gap-1"
            : "flex items-center gap-1"}
        >
          {channelId && <span class="w-1.5 h-1.5 rounded-full bg-primary" />}
          {channelName}
        </BreadcrumbPage>
      </BreadcrumbItem>
    </BreadcrumbList>
  </Breadcrumb>

  <!-- 右側: [ダークモード切替] | [GitHub] | [ログイン等] -->
  <div class="flex items-center gap-3">
    <!-- ダークモード切替 -->
    <ToggleTheme client:load />

    <!-- セパレーター -->
    <div class="h-5 w-px bg-border"></div>

    <!-- GitHub リンク -->
    <a
      href="https://github.com/y-exe/ymkw-top"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-center w-8 h-8 rounded-lg text-muted-foreground hover:text-foreground hover:bg-muted transition-all"
      aria-label="GitHub Repository"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
        <path
          d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
        ></path>
      </svg>
    </a>

    <!-- セパレーター -->
    <div class="h-5 w-px bg-border"></div>

    <!-- ログイン/ログアウト -->
    {
      userId && userId !== "guest" ? (
        <>
          <div class="text-right hidden md:flex flex-col justify-center flex-shrink-0">
            <p
              class="text-sm font-bold text-foreground leading-none truncate max-w-[300px] whitespace-nowrap"
              title={userName}
            >
              {userName}
            </p>
            <div class="flex items-center justify-end gap-1.5 mt-1">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75" />
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500" />
              </span>
              <span class="text-[10px] text-green-600 font-bold uppercase tracking-wider">
                Online
              </span>
            </div>
          </div>

          {userAvatar && userAvatar !== "None" ? (
            <img
              src={userAvatar}
              class="w-9 h-9 rounded-full border border-border shadow-sm object-cover flex-shrink-0"
            />
          ) : (
            <div class="w-9 h-9 rounded-full bg-primary text-primary-foreground flex items-center justify-center text-sm font-bold shadow-sm flex-shrink-0">
              {userName ? userName[0] : "U"}
            </div>
          )}

          <LogoutButton client:load />
        </>
      ) : (
        <LoginButton client:load />
      )
    }
  </div>
</header>
