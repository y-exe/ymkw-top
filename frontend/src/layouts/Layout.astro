---
import { ViewTransitions } from "astro:transitions";
import Sidebar from "../components/Sidebar.astro";
import Header from "../components/Header.astro";
import FooterSection from "../components/FooterSection.tsx";
import LoginModal from "../components/LoginModal.jsx";
import LoadingScreen from "../components/LoadingScreen.astro";
import MobileNavigation from "../components/MobileNavigation.jsx";
import ThemeProvider from "../components/ThemeProvider.jsx";
import "nprogress/nprogress.css";
import "../styles/global.css";

const {
  title,
  description = "YoutuberのDiscord鯖であるやまかわてるき鯖の活動量、ランキング、統計情報を可視化する公認WEBダッシュボード。個人の発言数推移やサーバー全体のトレンドを確認できます。",
  image,
  hideNavigation = false,
  noindex = false,
  breadcrumbs = [],
  jsonLd = [],
} = Astro.props;

const userId = Astro.cookies.get("user_id")?.value;
const userNameRaw = Astro.cookies.get("user_name")?.value;
const userName = userNameRaw ? decodeURIComponent(userNameRaw) : null;
const userAvatar = Astro.cookies.get("user_avatar")?.value;
const user = { id: userId, name: userName, avatar: userAvatar };

const currentPath = Astro.url.pathname;
const queryParams = Astro.url.search;
const primarySearchTerm = "やまかわてるき";
const siteName = "やまかわてるき鯖WEBダッシュボード";
const siteAlternateNames = ["やまかわてるき鯖", "ymkw.top"];
const seoKeywords = [
  primarySearchTerm,
  "やまかわてるき鯖",
  "ymkw",
  "ymkw.top",
  "Discord統計",
  "Discordランキング",
  "やまかわてるき 統計",
  "やまかわてるき ランキング",
  "やまかわてるき Discord",
];
const seoSubject = `${primarySearchTerm}, やまかわてるき鯖, ymkw.top`;
const seoAbstract = `${primarySearchTerm}、やまかわてるき鯖、Discord統計、ランキング、活動データを扱うymkw.topの公式ダッシュボード。`;

const parts = currentPath.split("/").filter(Boolean);
const isDashboard =
  currentPath.includes("/month/") || currentPath === "/all";

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://ymkw.top",
);
const imageURL = new URL(image || "/ranking.webp", canonicalURL).href;
const fullTitle =
  title === primarySearchTerm
    ? `${primarySearchTerm} | ${siteName}`
    : `${title} | ${primarySearchTerm} | ${siteName}`;
const topicSchema = {
  "@type": "Thing",
  name: primarySearchTerm,
  alternateName: "やまかわてるき鯖",
  description: "やまかわてるきに関連するDiscord統計情報。",
};
const publisherSchema = {
  "@type": "Organization",
  name: siteName,
  alternateName: siteAlternateNames,
  url: "https://www.ymkw.top",
  logo: new URL("/apple-touch-icon.png", canonicalURL).href,
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  alternateName: siteAlternateNames,
  url: "https://www.ymkw.top",
  description: description,
  inLanguage: "ja",
  keywords: seoKeywords,
  about: topicSchema,
  publisher: publisherSchema,
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: fullTitle,
  url: canonicalURL.href,
  description: description,
  inLanguage: "ja",
  keywords: seoKeywords,
  about: topicSchema,
  mainEntity: topicSchema,
  publisher: publisherSchema,
  isPartOf: {
    "@type": "WebSite",
    name: siteName,
    alternateName: siteAlternateNames,
    url: "https://www.ymkw.top",
  },
};

const datasetSchema = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  name: "やまかわてるき鯖 Discord統計データ",
  alternateName: [
    "やまかわてるき 統計",
    "やまかわてるき ランキング",
    "やまかわてるき Discord",
  ],
  description: seoAbstract,
  url: canonicalURL.href,
  keywords: seoKeywords,
  inLanguage: "ja",
  isAccessibleForFree: true,
  creator: publisherSchema,
  publisher: publisherSchema,
  about: topicSchema,
};

let breadcrumbSchema = null;
if (breadcrumbs.length > 0) {
  breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbs.map((item: any, index: number) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.name,
      item: item.item,
    })),
  };
}

const extraJsonLd = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={seoKeywords.join(", ")} />
    <meta name="application-name" content={siteName} />
    <meta name="author" content={siteName} />
    <meta name="subject" content={seoSubject} />
    <meta name="abstract" content={seoAbstract} />
    <meta name="classification" content="やまかわてるき Discord統計 ダッシュボード" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="ja" href={canonicalURL} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:alt" content={`${siteName} - ${primarySearchTerm}`} />
    <meta property="article:tag" content={primarySearchTerm} />
    <meta property="article:tag" content="やまかわてるき鯖" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={imageURL} />
    <meta property="twitter:image:alt" content={`${siteName} - ${primarySearchTerm}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Dela+Gothic+One&family=JetBrains+Mono:wght@400;700&family=Noto+Sans+JP:wght@400;700;900&family=Outfit:wght@400;700;800&display=swap"
      rel="stylesheet"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(webPageSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(datasetSchema)}
    />
    {
      breadcrumbSchema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(breadcrumbSchema)}
        />
      )
    }
    {
      extraJsonLd.filter(Boolean).map((schema: any) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(schema)}
        />
      ))
    }

    <ViewTransitions />
    <style is:global>
      #nprogress .bar {
        background: #3b82f6 !important;
        height: 3px !important;
        z-index: 10001 !important;
      }
      .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
      }
      .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #e5e7eb;
        border-radius: 20px;
      }
      .dark .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #4b5563;
      }

      @media (max-width: 767px) {
        .mobile-content-pt {
          padding-top: 8.5rem !important;
        }
      }
    </style>
  </head>
  <body
    class="bg-background text-foreground font-sans min-h-screen flex flex-col md:flex-row"
  >
    <ThemeProvider client:load>
      <LoadingScreen />

      {
        !hideNavigation ? (
          <>
            <Sidebar transition:persist />

            <div class="md:hidden">
              <MobileNavigation
                client:load
                user={user}
                currentPath={currentPath}
                queryParams={queryParams}
              />
            </div>

            <div class="flex-1 min-w-0 md:ml-80 flex flex-col transition-all mobile-content-pt relative">
              <Header />

              <main
                class={
                  isDashboard
                    ? "px-4 md:px-8 lg:px-12 lg:pt-0 lg:pb-0 flex-1 bg-white"
                    : "px-4 md:px-8 lg:p-12 flex-1 pb-32"
                }
              >
                <slot />
              </main>

              <FooterSection />
            </div>
          </>
        ) : (
          <main class="min-h-screen w-full relative">
            <slot />
          </main>
        )
      }

      <LoginModal client:load />

      <script>
        import NProgress from "nprogress";
        NProgress.configure({ showSpinner: false, speed: 400 });
        const shouldShowProgress = (event) => {
          const to = event.to?.url || event.to;
          const path = to
            ? new URL(to, window.location.href).pathname
            : window.location.pathname;
          return path.includes("/month/") || path === "/all";
        };
        document.addEventListener("astro:before-preparation", (event) => {
          if (shouldShowProgress(event)) NProgress.start();
        });
        window.addEventListener("app-loaded", () => NProgress.done());
        document.addEventListener("astro:after-swap", () =>
          setTimeout(() => NProgress.done(), 8000),
        );
      </script>
    </ThemeProvider>
  </body>
</html>
