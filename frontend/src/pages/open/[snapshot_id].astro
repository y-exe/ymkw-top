---
import Layout from "../../layouts/Layout.astro";
import SnapshotDashboard from "../../components/SnapshotDashboard.jsx";
import { fetchAPI } from "@/lib/api";
import { formatDate, formatNumber } from "@/lib/seo";

const { snapshot_id } = Astro.params;
const url = Astro.url;

if (snapshot_id === "total") return Astro.redirect("/");

const channelId = url.searchParams.get("channel");
let userId = Astro.cookies.get("user_id")?.value;
if (userId === "guest") userId = null;

let snapshotInfo: any = null;
let seoRanking: any[] = [];
let snapshotNotFound = false;
try {
  const infoRes = await fetchAPI(`/snapshots/${snapshot_id}`, { retries: 1 });
  if (infoRes.ok) {
    snapshotInfo = await infoRes.json();
    const endDate = encodeURIComponent(snapshotInfo.created_at);
    const rankingRes = await fetchAPI(`/ranking/total?end_date=${endDate}`, {
      retries: 1,
    });
    if (rankingRes.ok) {
      const ranking = await rankingRes.json();
      if (Array.isArray(ranking)) seoRanking = ranking.slice(0, 10);
    }
  } else if (infoRes.status === 404) {
    Astro.response.status = 404;
    snapshotNotFound = true;
  }
} catch (e) {
  console.error("Snapshot SEO Fetch Error:", e);
}

const isMissingSnapshot = snapshotNotFound;

Astro.response.headers.set(
  "Cache-Control",
  isMissingSnapshot ? "no-store" : "public, s-maxage=86400, max-age=3600",
);

const pageTitle = snapshotInfo?.title || `スナップショット #${snapshot_id}`;
const pageDescription = snapshotInfo
  ? `やまかわてるき鯖の全期間統計「${snapshotInfo.title}」。${formatDate(snapshotInfo.created_at)}時点の累計ランキング、活動履歴、ユーザー別統計を確認できます。`
  : `やまかわてるき鯖の全期間統計スナップショット #${snapshot_id} の詳細データ。`;

const breadcrumbs = [
  { name: "トップ", item: "https://www.ymkw.top/" },
  { name: "スナップショット", item: "https://www.ymkw.top/" },
  { name: `#${snapshot_id}`, item: `https://www.ymkw.top/open/${snapshot_id}` },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  breadcrumbs={breadcrumbs}
  noindex={isMissingSnapshot}
>
  {isMissingSnapshot ? (
    <section class="mx-auto flex min-h-[60vh] max-w-xl flex-col items-center justify-center text-center">
      <h1 class="text-3xl font-black text-gray-900">スナップショットが見つかりません</h1>
      <p class="mt-4 text-sm leading-7 text-gray-600">
        指定された全期間ランキングの記録は削除されたか、まだ作成されていません。
      </p>
      <a href="/" class="mt-8 rounded-md bg-gray-900 px-5 py-3 text-sm font-bold text-white">
        トップへ戻る
      </a>
    </section>
  ) : (
    <>
      <section class="mb-8 rounded-lg border border-gray-200 bg-white p-5 text-gray-900 shadow-sm">
        <h1 class="text-2xl font-black">{pageTitle}</h1>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-gray-600">{pageDescription}</p>
        {seoRanking.length > 0 && (
          <div class="mt-5">
            <h2 class="text-sm font-bold text-gray-700">累計ランキング上位</h2>
            <ol class="mt-3 grid gap-2 sm:grid-cols-2 lg:grid-cols-5">
              {seoRanking.slice(0, 5).map((item, index) => (
                <li class="rounded-md bg-gray-50 px-3 py-2 text-sm">
                  <span class="font-bold">{index + 1}位</span>
                  <span class="ml-2">{item.display_name || item.username}</span>
                  <span class="ml-1 text-gray-500">{formatNumber(item.count)}回</span>
                </li>
              ))}
            </ol>
          </div>
        )}
      </section>
      <SnapshotDashboard
        client:load
        snapshotId={snapshot_id}
        channelId={channelId}
        userId={userId}
      />
    </>
  )}
</Layout>
