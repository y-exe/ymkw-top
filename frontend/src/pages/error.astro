---
import Layout from "../layouts/Layout.astro";
import { WifiOff, ArrowLeft, Terminal } from "lucide-react";

const { url } = Astro;
const errorCode = url.searchParams.get("code") || "unknown";
const errorUrl = url.searchParams.get("url") || "";
const errorMsg = url.searchParams.get("msg") || "";
const currentOrigin = url.origin;
---

<Layout title="Connection Error" hideNavigation={true}>
  <div
    class="min-h-screen flex flex-col items-center justify-center p-6 bg-white font-sans text-center"
  >
    <div
      class="w-24 h-24 bg-red-50 text-red-400 rounded-[2rem] flex items-center justify-center mb-8 shadow-sm border border-red-100 animate-pulse"
    >
      <WifiOff className="w-10 h-10" />
    </div>

    <h1
      class="text-4xl font-black text-gray-900 mb-2 font-outfit tracking-tight"
    >
      API Connection Failed
    </h1>
    <p class="text-sm font-bold text-gray-400 mb-8 tracking-wide">
      Communication Error
    </p>

    <div class="flex flex-col gap-2 mb-8 max-w-lg w-full">
      <div
        class="flex items-center gap-2 px-4 py-2 bg-gray-50 border border-gray-100 rounded-xl font-mono text-xs text-gray-500"
      >
        <Terminal className="w-3 h-3 flex-shrink-0" />
        <span class="whitespace-nowrap">Error Code:</span>
        <span class="font-bold text-red-500">{errorCode}</span>
      </div>

      <div
        class="flex flex-col gap-3 px-4 py-4 bg-gray-50 border border-gray-100 rounded-xl font-mono text-[10px] text-gray-400 text-left overflow-hidden relative"
      >
        <div
          class="flex items-center gap-2 text-gray-400 uppercase font-black text-[9px] tracking-widest mb-1"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-gray-300"></span>
          Debug Information
        </div>

        {
          errorUrl && (
            <div class="space-y-1">
              <div class="text-[8px] text-gray-300 uppercase font-bold tracking-tighter">
                Failed Endpoint
              </div>
              <div class="break-all text-gray-500 border-l-2 border-red-100 pl-2">
                {errorUrl}
              </div>
            </div>
          )
        }

        {
          errorMsg && (
            <div class="space-y-1">
              <div class="text-[8px] text-gray-300 uppercase font-bold tracking-tighter">
                Error Message
              </div>
              <div class="break-all text-gray-500 italic">"{errorMsg}"</div>
            </div>
          )
        }

        <div class="space-y-1">
          <div
            class="text-[8px] text-gray-300 uppercase font-bold tracking-tighter"
          >
            Current Origin (Check CORS)
          </div>
          <div class="break-all text-gray-500">{currentOrigin}</div>
        </div>
      </div>
    </div>

    <p class="text-sm text-gray-500 mb-12 leading-relaxed max-w-xs mx-auto">
      APIサーバーへの接続に失敗しました。<br />
      サーバーが混み合っているか、<br />
      レート制限がかかっている可能性があります。<br />
      <span class="text-[10px] text-gray-400 mt-2 block"
        >※直接URLを叩いて表示される場合は、CORS（オリジン制限）が原因の可能性があります。</span
      >
    </p>

    <button
      onclick="window.location.reload()"
      class="px-8 py-4 bg-gray-900 text-white font-bold rounded-2xl hover:bg-black transition-all active:scale-95 shadow-xl shadow-gray-200 flex items-center gap-3"
    >
      <span>再読み込み</span>
    </button>

    <a
      href="/"
      class="mt-6 text-xs text-gray-400 font-bold hover:text-gray-600 transition-colors"
      >トップページへ戻る</a
    >
  </div>
</Layout>
